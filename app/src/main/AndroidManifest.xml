<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Write external storage — required for MediaStore on Android 9 and below (API < 29).
         On Android 10+ (API 29), MediaStore works without this permission. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Device permissions -->
    <uses-permission android:name="android.permission.VIBRATE"/>

    <!-- Contacts permission - optional, used to import participants from contacts -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Notification permission (required on Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Queries for intents (Android 11+) -->
    <queries>
        <!-- For sharing content -->
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="text/plain" />
        </intent>

        <!-- For picking contacts -->
        <intent>
            <action android:name="android.intent.action.PICK" />
            <data android:mimeType="vnd.android.cursor.dir/contact" />
        </intent>

        <!-- For sending SMS via default messaging app (no SEND_SMS permission required) -->
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="smsto" />
        </intent>

        <!-- Explicit package visibility for share targets (Android 11+).
             ACTION_SEND + text/plain covers official WhatsApp and Telegram, but
             Telegram FOSS may not register that filter — explicit package guarantees
             getPackageInfo() works for isTelegramInstalado(). -->
        <package android:name="com.whatsapp" />
        <package android:name="org.telegram.messenger" />
        <package android:name="org.telegram.messenger.foss" />
    </queries>

    <application
        android:name=".AmigoSecretoApplication"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:hardwareAccelerated="true"
        android:largeHeap="false"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".GruposActivity"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ParticipantesActivity"
            android:label="Participantes"
            android:exported="false">
        </activity>

        <activity
            android:name=".HistoricoSorteiosActivity"
            android:label="@string/historico_titulo"
            android:exported="false">
        </activity>

        <activity
            android:name=".RevelarAmigoActivity"
            android:label="Revelar Amigo Secreto"
            android:exported="false">
        </activity>

        <activity
            android:name=".ParticipanteDesejosActivity"
            android:label="Meus Desejos"
            android:exported="false">
        </activity>

        <activity
            android:name=".VisualizarDesejosActivity"
            android:label="Lista de Desejos"
            android:exported="false">
        </activity>

        <activity
            android:name=".ListarDesejos"
            android:exported="false" />
        <activity
            android:name=".InserirDesejoActivity"
            android:exported="false" />
        <activity
            android:name=".AlterarDesejoActivity"
            android:exported="false" />
        <activity
            android:name=".DetalheDesejoActivity"
            android:exported="false" />

        <activity
            android:name=".QrCodeActivity"
            android:label="@string/qr_menu_item"
            android:exported="false" />

        <activity
            android:name=".ConfiguracoesGrupoActivity"
            android:label="@string/configuracoes_grupo_titulo"
            android:exported="false" />

        <activity
            android:name=".DashboardActivity"
            android:label="@string/dashboard_titulo"
            android:exported="false" />

        <activity
            android:name=".EstatisticasActivity"
            android:label="@string/estatisticas_titulo"
            android:exported="false" />

        <activity
            android:name=".OnboardingActivity"
            android:label="@string/app_name"
            android:exported="false" />

        <!-- FileProvider for secure file sharing -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Disable default WorkManager auto-initialization so that AmigoSecretoApplication
             can provide HiltWorkerFactory via Configuration.Provider for @HiltWorker injection. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
