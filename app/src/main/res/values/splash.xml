<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Splash Screen theme for Android 12+ -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background color -->
        <item name="windowSplashScreenBackground">@color/md_theme_primary</item>

        <!-- Set the splash screen icon -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>

        <!-- Icon background (optional) -->
        <item name="windowSplashScreenIconBackgroundColor">@color/md_theme_primaryContainer</item>

        <!-- Branding image (optional) -->
        <item name="android:windowSplashScreenBrandingImage" tools:targetApi="31">@drawable/ic_gift</item>

        <!-- Post splash screen theme -->
        <item name="postSplashScreenTheme">@style/Theme.AmigoSecreto</item>
    </style>
</resources>