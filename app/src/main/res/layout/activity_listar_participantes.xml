<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/purple_primary"
        app:elevation="8dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_grupos"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="🎁 Amigo Secreto"
            app:titleCentered="true"
            app:titleTextColor="@color/white"
            app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/activity_horizontal_margin"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_manage_group"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/tv_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/label_no_participants"
                android:textColor="@color/text_on_color_surface"
                android:textSize="14sp" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_participantes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/layout_scroll_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/activity_horizontal_margin"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ViewStub
                android:id="@+id/stub_loading"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout="@layout/loading_state"
                android:visibility="gone" />

            <ViewStub
                android:id="@+id/stub_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout="@layout/empty_state"
                android:visibility="gone" />

            <ListView
                android:id="@+id/lv_participantes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="@android:color/transparent"
                android:dividerHeight="12dp"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:nestedScrollingEnabled="true"
                tools:listitem="@layout/item_participante" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Botões fixos na parte inferior -->
    <LinearLayout
        android:id="@+id/layout_bottom_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_buttons"
        android:paddingHorizontal="@dimen/activity_horizontal_margin"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:elevation="8dp">

        <!-- Botão Adicionar Participante -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab_add_participante"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:text="@string/button_add_participant"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="12dp"
            app:elevation="2dp"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:iconTint="@color/white" />

        <!-- Botão Realizar Sorteio -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sortear"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="4dp"
            android:text="@string/button_draw"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/gradient_green"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_dice"
            app:iconGravity="textStart"
            app:iconTint="@color/white" />

        <!-- Botão Limpar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_limpar"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/button_clear_participants"
            android:textAllCaps="false"
            android:textColor="@color/colorError" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
