<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Linha 1: número + avatar + nome/status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_numero"
                android:layout_width="20dp"
                android:layout_height="wrap_content"
                tools:text="1"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tv_avatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_background"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="A"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/tv_nome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Nome"/>

                <TextView
                    android:id="@+id/tv_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Status"/>

                <TextView
                    android:id="@+id/tv_desejos_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    tools:text="0 desejos"
                    android:textSize="11sp"
                    android:textColor="@color/colorAccent"
                    android:textStyle="bold"
                    android:drawablePadding="4dp"
                    android:visibility="gone"
                    app:drawableStartCompat="@drawable/ic_gift"
                    app:drawableTint="@color/colorAccent" />
            </LinearLayout>

        </LinearLayout>

        <!-- Linha 2: botões de ação alinhados à direita.
             layout_width/height define o tamanho visual (36dp);
             minWidth/minHeight garante touch target >= 48dp (Material Design + WCAG 2.5.5). -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingBottom="8dp"
            android:gravity="end">

            <ImageButton
                android:id="@+id/btn_desejos"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_gift"
                app:tint="@color/colorAccent"
                android:contentDescription="@string/cd_my_wishes"/>

            <ImageButton
                android:id="@+id/btn_regras"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_rules"
                app:tint="@color/colorPrimary"
                android:contentDescription="@string/cd_restrictions"/>

            <ImageButton
                android:id="@+id/btn_share"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_share"
                app:tint="@color/colorSecondary"
                android:contentDescription="@string/cd_share"
                android:visibility="gone"/>

            <ImageButton
                android:id="@+id/btn_editar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_edit"
                app:tint="@color/colorPrimary"
                android:contentDescription="@string/cd_edit"/>

            <ImageButton
                android:id="@+id/btn_remover"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_delete"
                app:tint="@color/colorError"
                android:contentDescription="@string/cd_remove_participant"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
