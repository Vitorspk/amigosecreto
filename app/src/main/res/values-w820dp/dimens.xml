    <!-- Bottom action buttons: increased padding on wide screens for visual balance -->
    <dimen name="bottom_buttons_horizontal_padding">64dp</dimen>

    <!-- Dialog width cap: prevents dialogs from stretching across the full tablet width -->
    <dimen name="dialog_max_width">480dp</dimen>
