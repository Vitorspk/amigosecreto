<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Gift icon with app's purple palette + gold ribbon (classic elegant combo) -->
    <group
        android:scaleX="0.72"
        android:scaleY="0.72"
        android:pivotX="54"
        android:pivotY="54">

        <!-- === GIFT BOX BODY - Purple Primary === -->
        <path
            android:pathData="M28,48 L80,48 L80,76 Q80,80 76,80 L32,80 Q28,80 28,76 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="28"
                    android:startY="48"
                    android:endX="80"
                    android:endY="80"
                    android:type="linear">
                    <item android:offset="0" android:color="#6B4CE6"/>
                    <item android:offset="1" android:color="#5339C9"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- === LID - Purple Medium === -->
        <path
            android:pathData="M24,36 Q24,32 28,32 L80,32 Q84,32 84,36 L84,48 L24,48 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="24"
                    android:startY="32"
                    android:endX="24"
                    android:endY="48"
                    android:type="linear">
                    <item android:offset="0" android:color="#8B6FE8"/>
                    <item android:offset="1" android:color="#6B4CE6"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- Lid bottom edge - Purple Dark -->
        <path
            android:pathData="M24,46 L84,46 L84,48 L24,48 Z"
            android:fillColor="#4527A0"/>

        <!-- === RIBBONS - Gold/Amber === -->

        <!-- Vertical ribbon on lid -->
        <path
            android:pathData="M50,32 L58,32 L58,48 L50,48 Z"
            android:fillColor="#FFC107"/>

        <!-- Vertical ribbon on box -->
        <path
            android:pathData="M50,48 L58,48 L58,80 L50,80 Z"
            android:fillColor="#FFC107"/>

        <!-- Horizontal ribbon on box -->
        <path
            android:pathData="M28,58 L80,58 L80,66 L28,66 Z"
            android:fillColor="#FFC107"/>

        <!-- Ribbon cross center - Darker gold -->
        <path
            android:pathData="M50,58 L58,58 L58,66 L50,66 Z"
            android:fillColor="#F9A825"/>

        <!-- === BOW - Bright Gold === -->

        <!-- Bow left loop -->
        <path
            android:pathData="M54,32 C50,28 38,18 32,22 C26,26 28,32 36,34 L54,34 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="32"
                    android:startY="18"
                    android:endX="46"
                    android:endY="34"
                    android:type="linear">
                    <item android:offset="0" android:color="#FFEE58"/>
                    <item android:offset="1" android:color="#FFD54F"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- Bow right loop -->
        <path
            android:pathData="M54,32 C58,28 70,18 76,22 C82,26 80,32 72,34 L54,34 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="76"
                    android:startY="18"
                    android:endX="62"
                    android:endY="34"
                    android:type="linear">
                    <item android:offset="0" android:color="#FFEE58"/>
                    <item android:offset="1" android:color="#FFD54F"/>
                </gradient>
            </aapt:attr>
        </path>

        <!-- Bow center knot -->
        <path
            android:pathData="M49,26 C50,22 58,22 59,26 C60,30 59,34 54,34 C49,34 48,30 49,26 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="49"
                    android:startY="22"
                    android:endX="59"
                    android:endY="34"
                    android:type="linear">
                    <item android:offset="0" android:color="#FFB300"/>
                    <item android:offset="1" android:color="#FF8F00"/>
                </gradient>
            </aapt:attr>
        </path>

    </group>

</vector>
